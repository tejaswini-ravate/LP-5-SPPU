/*
 * Parallel BFS and DFS using OpenMP
 * Fixed version of student code
 * Compile: g++ -fopenmp -o graph graph.cpp
 */

#include <iostream>
#include <vector>
#include <queue>
#include <omp.h>
using namespace std;

class Graph {
    int V;
    vector<vector<int>> adj;

public:
    Graph(int V) {
        this->V = V;
        adj.resize(V);
    }

    void addEdge(int u, int v) {
        adj[u].push_back(v);
        adj[v].push_back(u);   // undirected
    }

    // ══════════════════════════════════════════════
    //  PARALLEL BFS
    //  FIX: use index-based level vector instead of
    //  shared queue — avoids thread-unsafe queue pops
    // ══════════════════════════════════════════════
    void parallelBFS(int start) {
        vector<bool> visited(V, false);
        vector<int>  currentLevel, nextLevel;

        visited[start] = true;
        currentLevel.push_back(start);

        cout << "\nParallel BFS Traversal: ";

        while (!currentLevel.empty()) {
            // Print current level (serial — just for clean output)
            for (int node : currentLevel)
                cout << node << " ";

            nextLevel.clear();

            // FIX: parallel for over a vector (not a queue)
            // Each thread processes a different node's neighbors
            #pragma omp parallel for schedule(dynamic)
            for (int i = 0; i < (int)currentLevel.size(); i++) {
                int node = currentLevel[i];

                for (int neighbor : adj[node]) {
                    // FIX: critical guards both check + write
                    #pragma omp critical
                    {
                        if (!visited[neighbor]) {
                            visited[neighbor] = true;
                            nextLevel.push_back(neighbor);
                        }
                    }
                }
            }

            currentLevel = nextLevel;
        }
        cout << endl;
    }

    // ══════════════════════════════════════════════
    //  PARALLEL DFS UTILITY
    //  FIX: removed #pragma omp parallel for
    //  Use ONLY #pragma omp task — never mix
    //  parallel for and task in the same function
    // ══════════════════════════════════════════════
    void parallelDFSUtil(int node, vector<bool>& visited) {
        // Check + mark + print — all in one critical block
        bool alreadyVisited;
        #pragma omp critical
        {
            alreadyVisited = visited[node];
            if (!alreadyVisited) {
                visited[node] = true;
                cout << node << " ";
            }
        }

        if (alreadyVisited) return;

        // FIX: plain for loop + omp task (no parallel for here)
        for (int i = 0; i < (int)adj[node].size(); i++) {
            int neighbor = adj[node][i];

            bool shouldVisit = false;
            // FIX: check visited inside critical before spawning task
            #pragma omp critical
            {
                if (!visited[neighbor])
                    shouldVisit = true;
            }

            if (shouldVisit) {
                #pragma omp task
                parallelDFSUtil(neighbor, visited);
            }
        }
        #pragma omp taskwait   // FIX: wait for child tasks before returning
    }

    // ══════════════════════════════════════════════
    //  PARALLEL DFS
    //  This part was already correct in your code
    // ══════════════════════════════════════════════
    void parallelDFS(int start) {
        vector<bool> visited(V, false);
        cout << "\nParallel DFS Traversal: ";

        #pragma omp parallel
        {
            #pragma omp single       // one thread starts root task
            {
                parallelDFSUtil(start, visited);
            }
        }
        cout << endl;
    }
};

int main() {
    int V, E;
    cout << "Enter number of vertices: ";
    cin >> V;

    Graph g(V);

    cout << "Enter number of edges: ";
    cin >> E;

    cout << "Enter edges (u v):\n";
    for (int i = 0; i < E; i++) {
        int u, v;
        cin >> u >> v;
        g.addEdge(u, v);
    }

    int start;
    cout << "Enter starting vertex: ";
    cin >> start;

    g.parallelBFS(start);
    g.parallelDFS(start);

    return 0;
}
